generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Perfil {
  id           String            @id @default(uuid())
  nome         String            @unique
  descricao    String?
  criadoEm     DateTime          @default(now())
  atualizadoEm DateTime          @updatedAt
  permissoes   PerfilPermissao[]
  usuarios     Usuario[]

  @@map("perfis")
}

model Usuario {
  id                String             @id @default(uuid())
  nome              String
  email             String             @unique
  usuario           String             @unique
  senhaHash         String
  ativo             Boolean            @default(true)
  perfilId          String
  ultimoLogin       DateTime?
  criadoEm          DateTime           @default(now())
  atualizadoEm      DateTime           @updatedAt
  auditoriasGerais  AuditoriaGeral[]   @relation("AuditoriaUsuario")
  auditoriasProduto AuditoriaProduto[]
  ordens            OrdemServico[]
  refreshTokens     RefreshToken[]
  perfil            Perfil             @relation(fields: [perfilId], references: [id])

  @@index([usuario])
  @@index([email])
  @@map("usuarios")
}

model CategoriaProduto {
  id           String    @id @default(uuid())
  nome         String    @unique
  descricao    String?
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt
  produtos     Produto[]

  @@map("categorias_produto")
}

model Marca {
  id           String    @id @default(uuid())
  nome         String    @unique
  descricao    String?
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt
  produtos     Produto[]

  @@map("marcas")
}

model Fornecedor {
  id           String         @id @default(uuid())
  nome         String
  razaoSocial  String?
  cnpj         String?        @unique
  telefone     String?
  email        String?
  contato      String?
  ativo        Boolean        @default(true)
  criadoEm     DateTime       @default(now())
  atualizadoEm DateTime       @updatedAt
  pedidos      PedidoCompra[]
  produtos     Produto[]

  @@index([nome])
  @@map("fornecedores")
}

model Produto {
  id                String                @id @default(uuid())
  codigoInterno     String                @unique
  codigoFornecedor  String?
  nome              String
  categoriaId       String
  marcaId           String
  fornecedorId      String?
  custo             Decimal               @db.Decimal(12, 2)
  precoVenda        Decimal               @db.Decimal(12, 2)
  estoqueAtual      Int                   @default(0)
  estoqueMinimo     Int                   @default(0)
  localizacaoFisica String?
  ativo             Boolean               @default(true)
  criadoEm          DateTime              @default(now())
  atualizadoEm      DateTime              @updatedAt
  auditorias        AuditoriaProduto[]
  itensOS           ItemOS[]
  itensPedido       ItemPedidoCompra[]
  itensRecebimento  ItemRecebimento[]
  itensVenda        ItemVenda[]
  movimentacoes     MovimentacaoEstoque[]
  compatibilidades  ProdutoModelo[]
  documentosFiscais DocumentoFiscalItem[]

  // Cadastro fiscal do produto para emissão NF-e/NFC-e em ambiente multiempresa.
  ncm               String?
  cest              String?
  cfopPadrao        String?
  origemMercadoria  String?
  unidadeComercial  String? @default("UN")
  unidadeTributavel String? @default("UN")
  gtinEan           String?
  pesoLiquido       Decimal? @db.Decimal(12, 3)
  pesoBruto         Decimal? @db.Decimal(12, 3)
  cstCsosnIcms      String?
  pis               String?
  cofins            String?
  ipi               String?
  categoria         CategoriaProduto      @relation(fields: [categoriaId], references: [id])
  fornecedor        Fornecedor?           @relation(fields: [fornecedorId], references: [id])
  marca             Marca                 @relation(fields: [marcaId], references: [id])

  @@index([nome])
  @@index([categoriaId])
  @@index([marcaId])
  @@index([fornecedorId])
  @@map("produtos")
}

model ModeloAparelho {
  id               String          @id @default(uuid())
  fabricante       String
  nome             String
  variante         String?
  criadoEm         DateTime        @default(now())
  atualizadoEm     DateTime        @updatedAt
  compatibilidades ProdutoModelo[]

  @@index([fabricante])
  @@index([nome])
  @@map("modelos_aparelho")
}

model ProdutoModelo {
  produtoId String
  modeloId  String
  criadoEm  DateTime       @default(now())
  modelo    ModeloAparelho @relation(fields: [modeloId], references: [id], onDelete: Cascade)
  produto   Produto        @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@id([produtoId, modeloId])
  @@index([produtoId])
  @@index([modeloId])
  @@map("produto_modelos")
}

model MovimentacaoEstoque {
  id               String   @id @default(uuid())
  produtoId        String
  tipo             String
  quantidade       Int
  estoqueAnterior  Int
  estoquePosterior Int
  observacao       String?
  criadoEm         DateTime @default(now())
  produto          Produto  @relation(fields: [produtoId], references: [id])

  @@index([produtoId])
  @@index([tipo])
  @@index([criadoEm])
  @@map("movimentacoes_estoque")
}

model AuditoriaProduto {
  id          String   @id @default(uuid())
  produtoId   String
  usuarioId   String
  acao        String
  dadosAntes  Json?
  dadosDepois Json?
  criadoEm    DateTime @default(now())
  produto     Produto  @relation(fields: [produtoId], references: [id])
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])

  @@index([produtoId])
  @@index([usuarioId])
  @@index([acao])
  @@map("auditoria_produtos")
}

model RefreshToken {
  id        String   @id @default(uuid())
  usuarioId String
  token     String   @unique
  expiraEm  DateTime
  revogado  Boolean  @default(false)
  criadoEm  DateTime @default(now())
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([token])
  @@map("refresh_tokens")
}

model Modulo {
  id           String   @id @default(uuid())
  codigo       String   @unique
  nome         String
  descricao    String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  telas        Tela[]

  @@index([codigo])
  @@map("modulos")
}

model Tela {
  id           String      @id @default(uuid())
  moduloId     String
  codigo       String
  nome         String
  descricao    String?
  criadoEm     DateTime    @default(now())
  atualizadoEm DateTime    @updatedAt
  permissoes   Permissao[]
  modulo       Modulo      @relation(fields: [moduloId], references: [id], onDelete: Cascade)

  @@unique([moduloId, codigo])
  @@index([moduloId])
  @@map("telas")
}

model Permissao {
  id           String            @id @default(uuid())
  telaId       String
  codigo       String
  nome         String
  descricao    String?
  criadoEm     DateTime          @default(now())
  atualizadoEm DateTime          @updatedAt
  perfis       PerfilPermissao[]
  tela         Tela              @relation(fields: [telaId], references: [id], onDelete: Cascade)

  @@unique([telaId, codigo])
  @@index([telaId])
  @@map("permissoes")
}

model PerfilPermissao {
  perfilId    String
  permissaoId String
  criadoEm    DateTime  @default(now())
  perfil      Perfil    @relation(fields: [perfilId], references: [id], onDelete: Cascade)
  permissao   Permissao @relation(fields: [permissaoId], references: [id], onDelete: Cascade)

  @@id([perfilId, permissaoId])
  @@index([perfilId])
  @@index([permissaoId])
  @@map("perfil_permissoes")
}

model Cliente {
  id           String         @id @default(uuid())
  nome         String
  cpf          String?        @unique
  telefone     String?
  email        String?
  endereco     String?
  ativo        Boolean        @default(true)
  criadoEm     DateTime       @default(now())
  atualizadoEm DateTime       @updatedAt
  ordens       OrdemServico[]
  vendas       Venda[]
  documentosFiscais DocumentoFiscal[]

  @@index([nome])
  @@map("clientes")
}

model OrdemServico {
  id                String    @id @default(uuid())
  numero            String    @unique
  clienteId         String
  aparelho          String
  modelo            String
  imei              String?
  descricaoProblema String
  laudoTecnico      String?
  solucaoAplicada   String?
  status            String    @default("ABERTA")
  tecnicoId         String?
  valorServico      Decimal?  @db.Decimal(12, 2)
  observacoes       String?
  dataPrevisao      DateTime?
  dataConclusao     DateTime?
  criadoEm          DateTime  @default(now())
  atualizadoEm      DateTime  @updatedAt
  garantiaDias      Int?      @default(90)
  valorMaoObra      Decimal?  @db.Decimal(12, 2)
  itens             ItemOS[]
  cliente           Cliente   @relation(fields: [clienteId], references: [id])
  tecnico           Usuario?  @relation(fields: [tecnicoId], references: [id])
  documentosFiscais DocumentoFiscal[]

  @@index([clienteId])
  @@index([status])
  @@map("ordens_servico")
}

model PedidoCompra {
  id           String              @id @default(uuid())
  numero       String              @unique
  fornecedorId String
  status       String              @default("RASCUNHO")
  observacoes  String?
  valorTotal   Decimal             @default(0) @db.Decimal(12, 2)
  criadoEm     DateTime            @default(now())
  atualizadoEm DateTime            @updatedAt
  itens        ItemPedidoCompra[]
  fornecedor   Fornecedor          @relation(fields: [fornecedorId], references: [id])
  recebimentos RecebimentoCompra[]

  @@index([fornecedorId])
  @@index([status])
  @@map("pedidos_compra")
}

model ItemPedidoCompra {
  id            String       @id @default(uuid())
  pedidoId      String
  produtoId     String
  quantidade    Int
  qtdRecebida   Int          @default(0)
  custoUnitario Decimal      @db.Decimal(12, 2)
  criadoEm      DateTime     @default(now())
  pedido        PedidoCompra @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produto       Produto      @relation(fields: [produtoId], references: [id])

  @@index([pedidoId])
  @@index([produtoId])
  @@map("itens_pedido_compra")
}

model RecebimentoCompra {
  id          String            @id @default(uuid())
  pedidoId    String
  observacoes String?
  criadoEm    DateTime          @default(now())
  itens       ItemRecebimento[]
  pedido      PedidoCompra      @relation(fields: [pedidoId], references: [id])

  @@index([pedidoId])
  @@map("recebimentos_compra")
}

model ItemRecebimento {
  id            String            @id @default(uuid())
  recebimentoId String
  produtoId     String
  quantidade    Int
  criadoEm      DateTime          @default(now())
  produto       Produto           @relation(fields: [produtoId], references: [id])
  recebimento   RecebimentoCompra @relation(fields: [recebimentoId], references: [id], onDelete: Cascade)

  @@index([recebimentoId])
  @@map("itens_recebimento")
}

model Venda {
  id             String      @id @default(uuid())
  numero         String      @unique
  clienteId      String?
  status         String      @default("ABERTA")
  formaPagamento String?
  desconto       Decimal     @default(0) @db.Decimal(12, 2)
  valorTotal     Decimal     @default(0) @db.Decimal(12, 2)
  observacoes    String?
  criadoEm       DateTime    @default(now())
  atualizadoEm   DateTime    @updatedAt
  itens          ItemVenda[]
  cliente        Cliente?    @relation(fields: [clienteId], references: [id])
  documentosFiscais DocumentoFiscal[]

  @@index([clienteId])
  @@index([status])
  @@index([criadoEm])
  @@map("vendas")
}

model ItemVenda {
  id            String   @id @default(uuid())
  vendaId       String
  produtoId     String
  quantidade    Int
  precoUnitario Decimal  @db.Decimal(12, 2)
  desconto      Decimal  @default(0) @db.Decimal(12, 2)
  criadoEm      DateTime @default(now())
  produto       Produto  @relation(fields: [produtoId], references: [id])
  venda         Venda    @relation(fields: [vendaId], references: [id], onDelete: Cascade)

  @@index([vendaId])
  @@index([produtoId])
  @@map("itens_venda")
}

model ItemOS {
  id            String       @id @default(uuid())
  ordemId       String
  produtoId     String
  quantidade    Int
  precoUnitario Decimal      @db.Decimal(12, 2)
  criadoEm      DateTime     @default(now())
  ordem         OrdemServico @relation(fields: [ordemId], references: [id], onDelete: Cascade)
  produto       Produto      @relation(fields: [produtoId], references: [id])

  @@index([ordemId])
  @@index([produtoId])
  @@map("itens_os")
}

model AuditoriaGeral {
  id          String   @id @default(uuid())
  usuarioId   String?
  tabela      String
  registro    String
  acao        String
  dadosAntes  Json?
  dadosDepois Json?
  ip          String?
  criadoEm    DateTime @default(now())
  usuario     Usuario? @relation("AuditoriaUsuario", fields: [usuarioId], references: [id])

  @@index([tabela])
  @@index([usuarioId])
  @@index([criadoEm])
  @@map("auditoria_geral")
}

model ConfiguracaoSistema {
  id                        String    @id @default(uuid())

  empresaId                 String?
  cnpj                      String?
  nomeEmpresa               String?

  instalacaoId              String?   @unique
  hardwareFingerprint       String?

  versaoSistema             String?

  licencaStatus             String?
  licencaPlano              String?

  licencaEmitidaEm          DateTime?
  licencaExpiraEm           DateTime?

  ultimaValidacaoLicenca    DateTime?
  proximaValidacaoLicenca   DateTime?
  ultimaSincronizacaoApi    DateTime?

  activationHash            String?

  licencaArquivoHash        String?
  licencaArquivoRecebidoEm  DateTime?

  // Controle de Replay/Downgrade Attack
  nonceLicenca              Int?

  criadoEm                  DateTime @default(now())
  atualizadoEm              DateTime @updatedAt

  @@index([cnpj])
  @@index([licencaStatus])

  @@map("configuracoes_sistema")
}


model Empresa {
  id           String   @id @default(uuid())
  nome         String
  cnpj         String   @unique
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  filiais      Filial[]
  documentosFiscais DocumentoFiscal[]

  @@index([nome])
  @@map("empresas")
}

model Filial {
  id           String   @id @default(uuid())
  empresaId    String
  nome         String
  cnpj         String   @unique
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  empresa      Empresa  @relation(fields: [empresaId], references: [id])
  emitentes    EmitenteFiscal[]
  documentosFiscais DocumentoFiscal[]

  @@index([empresaId])
  @@map("filiais")
}

model EmitenteFiscal {
  id                    String   @id @default(uuid())
  filialId              String?
  cnpj                  String   @unique
  razaoSocial           String
  nomeFantasia          String?
  inscricaoEstadual     String?
  inscricaoMunicipal    String?
  crt                   String?
  cnae                  String?
  logradouro            String?
  numero                String?
  complemento           String?
  bairro                String?
  municipio             String?
  municipioIbge         String?
  uf                    String
  cep                   String?
  certificadoReferencia String?
  ambienteFiscal        String   @default("HOMOLOGACAO")
  serieNfe              Int      @default(1)
  serieNfce             Int      @default(1)
  cscId                 String?
  cscTokenReferencia    String?
  ativo                 Boolean  @default(true)
  criadoEm              DateTime @default(now())
  atualizadoEm          DateTime @updatedAt
  filial                Filial?  @relation(fields: [filialId], references: [id])
  documentosFiscais     DocumentoFiscal[]
  series                SerieFiscal[]

  @@index([filialId])
  @@index([ambienteFiscal])
  @@index([uf])
  @@map("emitentes_fiscais")
}

model SerieFiscal {
  id              String   @id @default(uuid())
  emitenteId      String
  modelo          String
  serie           Int
  proximoNumero   Int      @default(1)
  ambienteFiscal  String   @default("HOMOLOGACAO")
  ativo           Boolean  @default(true)
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt
  emitente        EmitenteFiscal @relation(fields: [emitenteId], references: [id])
  documentosFiscais DocumentoFiscal[]

  @@unique([emitenteId, modelo, serie, ambienteFiscal])
  @@index([emitenteId])
  @@map("series_fiscais")
}

model NaturezaOperacao {
  id           String   @id @default(uuid())
  descricao    String
  tipoOperacao String
  cfopPadrao   String?
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  documentosFiscais DocumentoFiscal[]
  regrasTributarias RegraTributaria[]

  @@index([tipoOperacao])
  @@map("naturezas_operacao")
}

model RegraTributaria {
  id                 String   @id @default(uuid())
  naturezaOperacaoId String?
  regimeTributario   String?
  ufOrigem           String?
  ufDestino          String?
  ncm                String?
  cfop               String?
  cstCsosnIcms       String?
  aliquotaIcms       Decimal? @db.Decimal(7, 4)
  pis                String?
  aliquotaPis        Decimal? @db.Decimal(7, 4)
  cofins             String?
  aliquotaCofins     Decimal? @db.Decimal(7, 4)
  ipi                String?
  aliquotaIpi        Decimal? @db.Decimal(7, 4)
  ativo              Boolean  @default(true)
  criadoEm           DateTime @default(now())
  atualizadoEm       DateTime @updatedAt
  naturezaOperacao   NaturezaOperacao? @relation(fields: [naturezaOperacaoId], references: [id])

  @@index([naturezaOperacaoId])
  @@index([regimeTributario])
  @@index([ufOrigem, ufDestino])
  @@index([ncm])
  @@map("regras_tributarias")
}

model DocumentoFiscal {
  id                 String   @id @default(uuid())
  empresaId          String?
  filialId           String?
  emitenteId         String?
  serieFiscalId      String?
  naturezaOperacaoId String?
  vendaId            String?
  ordemServicoId     String?
  clienteId          String?
  modelo             String   @default("55")
  numero             Int?
  serie              Int?
  chave              String?  @unique
  clienteNome        String?
  valorTotal         Decimal  @default(0) @db.Decimal(12, 2)
  statusInterno      String   @default("RASCUNHO")
  statusSefaz        String?
  ambienteFiscal     String   @default("HOMOLOGACAO")
  dataEmissao        DateTime?
  protocolo          String?
  justificativa      String?
  nfewebId           String?
  payloadFiscal      Json?
  retornoGateway     Json?
  criadoEm           DateTime @default(now())
  atualizadoEm       DateTime @updatedAt
  empresa            Empresa? @relation(fields: [empresaId], references: [id])
  filial             Filial? @relation(fields: [filialId], references: [id])
  emitente           EmitenteFiscal? @relation(fields: [emitenteId], references: [id])
  serieFiscal        SerieFiscal? @relation(fields: [serieFiscalId], references: [id])
  naturezaOperacao   NaturezaOperacao? @relation(fields: [naturezaOperacaoId], references: [id])
  venda              Venda? @relation(fields: [vendaId], references: [id])
  ordemServico       OrdemServico? @relation(fields: [ordemServicoId], references: [id])
  cliente            Cliente? @relation(fields: [clienteId], references: [id])
  itens              DocumentoFiscalItem[]
  eventos            DocumentoFiscalEvento[]
  xmls               DocumentoFiscalXml[]
  historicoStatus    DocumentoFiscalStatusHistorico[]

  @@index([empresaId])
  @@index([vendaId])
  @@index([ordemServicoId])
  @@index([clienteId])
  @@index([statusInterno])
  @@index([statusSefaz])
  @@index([ambienteFiscal])
  @@index([dataEmissao])
  @@map("documentos_fiscais")
}

model DocumentoFiscalItem {
  id                 String   @id @default(uuid())
  documentoFiscalId  String
  produtoId          String?
  codigoProduto      String?
  descricao          String
  ncm                String?
  cest               String?
  cfop               String?
  unidadeComercial   String?  @default("UN")
  unidadeTributavel  String?  @default("UN")
  gtinEan            String?
  quantidade         Decimal  @db.Decimal(12, 4)
  valorUnitario      Decimal  @db.Decimal(12, 4)
  valorTotal         Decimal  @db.Decimal(12, 2)
  cstCsosnIcms       String?
  pis                String?
  cofins             String?
  ipi                String?
  criadoEm           DateTime @default(now())
  documentoFiscal    DocumentoFiscal @relation(fields: [documentoFiscalId], references: [id], onDelete: Cascade)
  produto            Produto? @relation(fields: [produtoId], references: [id])

  @@index([documentoFiscalId])
  @@index([produtoId])
  @@map("documentos_fiscais_itens")
}

model DocumentoFiscalEvento {
  id                String   @id @default(uuid())
  documentoFiscalId String
  tipo              String
  status            String?
  protocolo         String?
  justificativa     String?
  retornoGateway    Json?
  criadoEm          DateTime @default(now())
  documentoFiscal   DocumentoFiscal @relation(fields: [documentoFiscalId], references: [id], onDelete: Cascade)

  @@index([documentoFiscalId])
  @@index([tipo])
  @@index([criadoEm])
  @@map("documentos_fiscais_eventos")
}

model DocumentoFiscalXml {
  id                String   @id @default(uuid())
  documentoFiscalId String
  tipo              String
  xml               String
  hash              String?
  criadoEm          DateTime @default(now())
  documentoFiscal   DocumentoFiscal @relation(fields: [documentoFiscalId], references: [id], onDelete: Cascade)

  @@index([documentoFiscalId])
  @@index([tipo])
  @@map("documentos_fiscais_xml")
}

model DocumentoFiscalStatusHistorico {
  id                String   @id @default(uuid())
  documentoFiscalId String
  statusAnterior    String?
  statusNovo        String
  statusSefaz       String?
  observacao        String?
  criadoEm          DateTime @default(now())
  documentoFiscal   DocumentoFiscal @relation(fields: [documentoFiscalId], references: [id], onDelete: Cascade)

  @@index([documentoFiscalId])
  @@index([statusNovo])
  @@index([criadoEm])
  @@map("documentos_fiscais_status_historico")
}
