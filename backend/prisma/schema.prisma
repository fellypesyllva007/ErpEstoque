model SaasPlano {
  id           String   @id @default(uuid())
  codigo       String   @unique
  nome         String
  descricao    String?
  valorMensal  Decimal  @db.Decimal(12, 2)
  limiteUsuarios Int    @default(3)
  limiteFiliais Int     @default(1)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  assinaturas  SaasAssinatura[]

  @@index([ativo])
  @@map("saas_planos")
}

model SaasAssinatura {
  id           String   @id @default(uuid())
  empresaId    String
  planoId      String
  status       String   @default("ATIVA")
  valorMensal  Decimal  @db.Decimal(12, 2)
  ciclo        String   @default("MENSAL")
  inicioEm     DateTime @default(now())
  proximaCobrancaEm DateTime
  canceladaEm  DateTime?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  empresa      Empresa  @relation(fields: [empresaId], references: [id])
  plano        SaasPlano @relation(fields: [planoId], references: [id])

  @@index([empresaId])
  @@index([planoId])
  @@index([status])
  @@map("saas_assinaturas")
}
